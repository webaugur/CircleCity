<?xml version="1.0" encoding="UTF-8"?>
<ns0:kml xmlns:ns0="http://www.opengis.net/kml/2.2">
  <ns0:Document>
    <ns0:name>IU Seismograph Network</ns0:name>
    <ns0:description>Stations on ground; Rainbow Rings (6 ground diameters); Line + Circle Layer at 100 km.</ns0:description>
    <ns0:Style id="redArc">
      <ns0:LineStyle>
        <ns0:color>ff0000ff</ns0:color>
        <ns0:width>7</ns0:width>
      </ns0:LineStyle>
    </ns0:Style>
    <ns0:Style id="circleLayer">
      <ns0:LineStyle>
        <ns0:color>ff0000ff</ns0:color>
        <ns0:width>13</ns0:width>
      </ns0:LineStyle>
      <ns0:PolyStyle>
        <ns0:color>00000000</ns0:color>
        <ns0:fill>0</ns0:fill>
        <ns0:outline>1</ns0:outline>
      </ns0:PolyStyle>
    </ns0:Style>
    <ns0:Folder>
      <ns0:name>Reference Points</ns0:name>
      <ns0:Placemark>
        <ns0:name>ZeroPoint</ns0:name>
        <ns0:description>Internal reference — 0.0, 0.0</ns0:description>
        <ns0:Point>
          <ns0:coordinates>0,0,0</ns0:coordinates>
          <ns0:altitudeMode>clampToGround</ns0:altitudeMode>
        </ns0:Point>
        <ns0:ExtendedData>
          <ns0:Data name="station_code">
            <ns0:value>ZeroPoint</ns0:value>
          </ns0:Data>
        </ns0:ExtendedData>
      </ns0:Placemark>
    </ns0:Folder>
    <ns0:Folder>
      <ns0:name>Stations</ns0:name>
      <ns0:description>Every placemark here is a station anchor. kml_sync.py redraws attached lines, circles, and rainbow rings on move.</ns0:description>
