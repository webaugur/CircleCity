<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Seismic Network (legacy file link)</name>
    <description>
      Superseded by the HTTP NetworkLink served at http://127.0.0.1:8765/link.kml
      when you run ./tools/bin/start-earth-sync.sh.

      Google Earth saves edits to ~/.googleearth/myplaces.kml, not this file.
      See Docs/networklink-architecture.md.
    </description>
    <NetworkLink>
      <name>seismic_network.kml</name>
      <open>1</open>
      <Link>
        <href>seismic_network.kml</href>
        <refreshMode>onChange</refreshMode>
        <refreshInterval>2</refreshInterval>
      </Link>
    </NetworkLink>
  </Document>
</kml>