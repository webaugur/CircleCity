<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Seismic Network (live)</name>
    <description>
      Auto-reloads seismic_network.kml when kml_sync.py --watch rewrites it.

      Workflow:
      1. Run ./tools/bin/start-earth-sync.sh
      2. Edit seismic_network.kml (opened directly); NetworkLink here auto-reloads it
      3. Drag stations under Stations, Save (Ctrl+S)
      4. Watch redraws lines/circles/rainbow; href onChange refresh fires on file:// target

      Data lives in data/; sync scripts in tools/bin/.
      Sync rewrites href to a local file:// URI at startup.
    </description>
    <NetworkLink>
      <name>seismic_network.kml</name>
      <open>1</open>
      <refreshVisibility>1</refreshVisibility>
      <flyToView>0</flyToView>
      <Link>
        <href>seismic_network.kml</href>
        <refreshMode>onChange</refreshMode>
        <refreshInterval>2</refreshInterval>
        <viewRefreshMode>onRequest</viewRefreshMode>
        <viewRefreshTime>1</viewRefreshTime>
      </Link>
    </NetworkLink>
  </Document>
</kml>